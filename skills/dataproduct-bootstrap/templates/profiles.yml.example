{{DBT_PROJECT_NAME}}:
  target: dev
  outputs:
    dev:
      type: snowflake
      account: <fill in>
      user: <fill in>
      password: <fill in>
      role: <fill in>
      database: {{DATABASE}}
      warehouse: <fill in>
      # Profile schema is dbt's fallback default; with the `generate_schema_name`
      # macro override in macros/get_custom_schema.sql, each layer overrides it:
      #   staging/ + intermediate/  →  internal_{{DBT_PROJECT_NAME}}
      #   output_ports/v1/<table>   →  op_<table>_v1   (only public surface)
      schema: {{DBT_PROJECT_NAME}}
      threads: 4
